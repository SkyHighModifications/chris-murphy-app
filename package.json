{
  "name": "cripmurphy",
  "productName": "ChrisMurphy",
  "version": "2.0.0",
  "description": "Chris Murphy Work Templates Save as PDF Application",
  "main": "main.js",
  "author": "Kieran Murphy",
  "appId": "uk.co.murphy.chris",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyHighModifications/chris-murphy-app.git"
  },
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder --publish always",
    "dist": "electron-builder",
    "start": "electron ."
  },
  "build": {
    "appId": "uk.co.murphy.chris",
    "buildDependenciesFromSource": false,
    "publish": {
      "provider": "github",
      "owner": "SkyHighModifications",
      "repo": "chris-murphy-app",
      "releaseType": "release"
    },
    "compression": "maximum",
    "asar": true,
    "copyright": "© 2026 Kieran Murphy. All rights reserved.",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "customers.json",
      "changelog.json",
      "main.js",
      "updater.js",
      "splash-preload.js",
      "preload.js",
      "package.json",
      "splash.html",
      "index.html",
      "templates/**",
      "css/**",
      "assets/**",
      "style.css",
      "renderer/**",
      "modules/**",
      "!**/*.map",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.ts",
      "!docs/**"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "electronLanguages": [
      "en-GB"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-${version}.exe",
      "publisherName": "Kieran Murphy",
      "icon": "assets/cm.ico"
    },
    "nsis": {
      "guid": "8f5d9b8d-7a4f-4d7e-9b27-2d2675a5c9f1",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chris Murphy",
      "runAfterFinish": true,
      "installerIcon": "assets/cm.ico",
      "uninstallerIcon": "assets/cm.ico",
      "installerHeaderIcon": "assets/cm.ico",
      "installerSidebar": "assets/installer.bmp",
      "uninstallerSidebar": "assets/uninstaller.bmp",
      "menuCategory": true,
      "deleteAppDataOnUninstall": false,
      "displayLanguageSelector": false,
      "artifactName": "${productName}-Setup-${version}.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "html2pdf.js": "^0.10.3",
    "lucide": "^1.17.0"
  }
}
